<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.study.mapper.ResumeTemplateMapper">

    <resultMap id="ResumeTemplateResultMap" type="com.ai.study.domain.ResumeTemplate">
        <id property="id" column="id" />
        <result property="name" column="name" />
        <result property="category" column="category" />
        <result property="thumbnail" column="thumbnail" />
        <result property="content" column="content" />
        <result property="isActive" column="is_active" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <select id="findAllActive" resultMap="ResumeTemplateResultMap">
        SELECT * FROM resume_template WHERE is_active = 1 ORDER BY id ASC
    </select>

    <select id="findById" resultMap="ResumeTemplateResultMap">
        SELECT * FROM resume_template WHERE id = #{id}
    </select>

</mapper>
